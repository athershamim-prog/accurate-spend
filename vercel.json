{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/solutions/accurate-spend", "destination": "/solutions-accurate-spend.html" }
  ],
  "redirects": [
    { "source": "/services-compliance-hub", "destination": "/accurate-ai", "permanent": true },
    { "source": "/services-compliance-hub.html", "destination": "/accurate-ai", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
